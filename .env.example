# Supabase — client-safe (exposed to the browser)
NEXT_PUBLIC_SUPABASE_URL=
# New-style key (used by the app). Format: sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase — server-only. NEVER expose to the client. Bypasses RLS.
# Used for guest order writes/reads (guests have no auth identity).
SUPABASE_SERVICE_ROLE_KEY=

# Store
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Telegram order notifications — server-only. NEVER expose to the client.
# TELEGRAM_BOT_TOKEN: from @BotFather (e.g. 123456789:ABCdef...).
# TELEGRAM_CHAT_ID: the target group's chat id (negative for groups, e.g. -1001234567890).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Shift reminders — server-only. Shared secret the Supabase pg_cron job sends in
# the `x-shift-cron-secret` header when it POSTs /api/shift/reminder. Set the same
# value here (App Service env) and in the cron job. Generate a random string.
SHIFT_CRON_SECRET=

# CHIP Collect (payment gateway) — Test Mode credentials.
# Get from https://portal.chip-in.asia/collect → Developers (toggle Test Mode ON).
# Server-only — never prefix with NEXT_PUBLIC_. Live values swap these when going live.
CHIP_SECRET_KEY=
CHIP_PUBLIC_KEY=
CHIP_BRAND_ID=
