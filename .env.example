# Supabase — client-safe (exposed to the browser)
NEXT_PUBLIC_SUPABASE_URL=
# New-style key (used by the app). Format: sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy key — kept as a placeholder for any future server-side tooling that still expects it.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only. NEVER import into client components.
SUPABASE_SERVICE_ROLE_KEY=

# Store
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp ordering — number in international format, digits only (e.g. 60123456789)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Telegram order notifications — server-only. NEVER expose to the client.
# TELEGRAM_BOT_TOKEN: from @BotFather (e.g. 123456789:ABCdef...).
# TELEGRAM_CHAT_ID: the target group's chat id (negative for groups, e.g. -1001234567890).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
