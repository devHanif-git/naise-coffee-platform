# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# cloudflare (opennext build output + local wrangler cache + local dev vars)
/.open-next/
/.wrangler/
.dev.vars
!.dev.vars.example

# production
/build

# misc
.DS_Store

# secrets / credentials — never commit keys, certs, or service-account files
*.pem
*.key
*.p12
*.pfx
*.crt
*-key.json
service-account*.json
gha-creds-*.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# CHIP payment gateway credentials — never commit
chip.env

# CHIP sandbox scratch scripts — local exploration only, never commit/deploy
chip-sandbox/

# local MCP config (may contain tokens)
.mcp.json

# vercel
.vercel

# IDE / editor
.vscode/
.idea/

# Claude Code (local, machine-specific settings)
.claude/settings.local.json

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase CLI scratch
/supabase/.temp/

# Serwist-generated service worker (built from app/sw.ts)
public/sw.js
public/sw.js.map
public/swe-worker-*.js
